# 环境变量配置模板
# 复制此文件为 .env 并填入实际配置值
# 注意：.env 文件不应提交到版本控制系统

# 服务器配置（本地调试默认建议）
VITE_SERVER_HOST=127.0.0.1
VITE_SERVER_PORT=3002
VITE_TUNNEL_URL=
VITE_USE_TUNNEL=false

# 微信云托管配置（本地H5调试请关闭）
VITE_USE_CLOUD_CONTAINER=false
VITE_CLOUD_ENV=your_wechat_cloud_environment_id
VITE_CLOUD_SERVICE=your_wechat_cloud_service_name

#阿里云oss配置
VITE_OSS_DOMAIN=YOUR-DOMAIN
VITE_OSS_BUCKET= YOUR-BUCKET
VITE_OSS_REGION=YOUR-REGION
